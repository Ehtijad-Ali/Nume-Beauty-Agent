# ============================================================
# NUMÉ Fullstack — Environment configuration
# Copy this file to ./backend/.env and ./frontend/.env
# (or use the per-folder .env.example files)
# ============================================================

# --- Shared ---
POSTGRES_USER=nume
POSTGRES_PASSWORD=nume_secret
POSTGRES_DB=nume
APP_ENV=development

# --- Backend (./backend/.env) ---
DATABASE_URL=postgresql+psycopg2://nume:nume_secret@localhost:5432/nume
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-long-random-string-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50
FRONTEND_URL=http://localhost:5173
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# --- Frontend (./frontend/.env) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
