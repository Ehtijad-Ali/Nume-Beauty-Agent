# ============================================================
# NUMÉ Backend — Environment configuration
# Copy this file to `.env` and adjust values.
# ============================================================

# --- Application ---
APP_NAME=NUMÉ AI Marketing Assistant
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.1.0

# --- Frontend URL (used by CORS) ---
FRONTEND_URL=http://localhost:5173

# --- PostgreSQL ---
POSTGRES_USER=nume
POSTGRES_PASSWORD=nume_secret
POSTGRES_DB=nume
DATABASE_URL=postgresql+psycopg2://nume:nume_secret@localhost:5432/nume

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Security ---
BCRYPT_ROUNDS=12

# --- File uploads ---
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- AI provider keys (stored but NOT used in Phase 1.1) ---
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
